{
  "firestore": {
    "database": "ishanktextiles",
    "location": "asia-south2",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "src/**",
      "tests/**",
      "package.json",
      "package-lock.json",
      "tsconfig.json",
      "next.config.js",
      "postcss.config.js",
      "tailwind.config.js",
      ".eslintrc.json",
      "jest.config.js",
      "TEST_READY.md",
      "ORIGINAL_REQUEST.md",
      "FIREBASE_MIGRATION.md",
      "next-env.d.ts"
    ]
  },
  "storage": {
    "rules": "storage.rules"
  }
}
